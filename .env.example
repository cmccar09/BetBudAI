# BetBudAI Environment Variables Template

# ── AWS Configuration ────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=813281204422

# ── Environment ──────────────────────────────────────────────────────────────
ENV=development  # development | staging | production
DEBUG=false

# ── Flask Configuration ──────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-here

# ── DynamoDB Tables ──────────────────────────────────────────────────────────
DYNAMODB_TABLE_PICKS=SureBetBets
DYNAMODB_TABLE_USERS=BetBudAI_Subscribers
DYNAMODB_TABLE_CONFIG=SureBetConfig
DYNAMODB_TABLE_AGENT_JOBS=SureBetAgentJobs

# ── API Credentials (from AWS Secrets Manager) ───────────────────────────────
# These are pulled from Secrets Manager in Lambda
# Set locally for development if testing external APIs
BETFAIR_USERNAME=your-betfair-username
BETFAIR_PASSWORD=your-betfair-password
BETFAIR_APP_KEY=your-app-key

RACING_API_USERNAME=your-racing-api-username
RACING_API_PASSWORD=your-racing-api-password

# ── AI/ML Services ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Email Configuration (SES) ────────────────────────────────────────────────
SES_REGION=eu-west-1
SES_SENDER=noreply@betbudai.com
SES_RECIPIENT_DEBUG=your-email@example.com

# ── Frontend Configuration ───────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000
REACT_APP_ENV=development
REACT_APP_VERSION=2.0.0
REACT_APP_GA_MEASUREMENT_ID=

# ── GA4 Reporting API ───────────────────────────────────────────────────────
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON=
GA4_SERVICE_ACCOUNT_JSON_B64=
GA4_SERVICE_ACCOUNT_SECRET_NAME=

# ── Monitoring ───────────────────────────────────────────────────────────────
ENABLE_XRAY=false
ENABLE_CLOUDWATCH_INSIGHTS=true

# ── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_AGENTIC_AI=true
FEATURE_PAYMENT=false
FEATURE_REALTIME_UPDATES=false
FEATURE_FREE_FEEDS=true

# ── Free Data Providers (Optional) ───────────────────────────────────────────
# Open-Meteo is keyless; this is a placeholder if you switch provider later.
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# Optional Met Office DataPoint key for dual-source weather confirmation.
# Leave empty to run keyless weather only.
MET_OFFICE_DATAPOINT_KEY=

# ── Pipeline Configuration ───────────────────────────────────────────────────
PIPELINE_BUCKET=surebet-pipeline-data
MORNING_RUN_TIME=08:30  # UTC
EVENING_RUN_TIME=20:00  # UTC
LEARNING_RUN_TIME=22:00  # UTC
